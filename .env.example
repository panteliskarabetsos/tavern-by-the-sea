# Copy to .env.local. Without RESEND_API_KEY the careers form renders, but tells
# applicants up front that it cannot deliver and points them at the email address.

# https://resend.com/api-keys
RESEND_API_KEY=

# Must be a domain verified in Resend, or delivery is rejected.
CAREERS_FROM="Tavern Careers <careers@tavernbytheseari.com>"

# Where applications land.
CAREERS_TO=careers@tavernbytheseari.com
